# Google Cloud Project Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_MULTI_REGION=us

# CX Agent Studio Configuration
CES_APP_ID=your-agent-app-id
CES_AGENT_ID=your-agent-id

# Authentication
# Use one of: service account key file, workload identity, or ADC
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Deployment Environment (dev | staging | production)
DEPLOY_ENV=dev

# Cloud Storage bucket for agent exports
GCS_BUCKET_NAME=your-project-agent-exports

# Notification webhook (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
